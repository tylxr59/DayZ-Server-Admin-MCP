DAYZ_REMOTE_PROTOCOL=sftp
DAYZ_REMOTE_HOST=example.com
DAYZ_REMOTE_PORT=22
DAYZ_REMOTE_USER=dayz-admin
DAYZ_REMOTE_PASSWORD=change-me
DAYZ_REMOTE_ROOT=/path/to/dayz/server
DAYZ_REMOTE_TIMEOUT=30
DAYZ_FTP_PASSIVE=true
DAYZ_SFTP_STRICT_HOST_KEY_CHECKING=false
DAYZ_MCP_ALLOW_WRITES=false
DAYZ_MCP_MAX_READ_BYTES=1048576
DAYZ_MCP_MAX_DOWNLOAD_BYTES=52428800
# DAYZ_MCP_DOWNLOAD_DIR=/tmp
